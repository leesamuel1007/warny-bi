    "WARNY_QUERY_LOG_ENABLED": "true",
    "WARNY_QUERY_LOG_PIPELINE": "azure",
    "SqlConnectionString": "Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  }
