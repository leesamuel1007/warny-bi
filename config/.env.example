# WARNY-BI local FOSS Runtime Configuration.
# Use as template for local secrets.

# SQL Server
DATA_DIR=data/processed
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_SERVER=127.0.0.1,1433
SQL_DATABASE=warny_bi
SQL_USER=warny_ingest
SQL_PASSWORD=<your_password_here>
SQL_LOAD_BATCH_SIZE=500

# RAG retrieval view
RAG_VIEW=dbo.vw_rag_documents

# OpenSearch
OPENSEARCH_URL=http://127.0.0.1:9200
OPENSEARCH_INDEX=warny_bi_rag

# Ollama
OLLAMA_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=mxbai-embed-large
CHAT_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=120

# FastAPI
API_HOST=0.0.0.0
API_PORT=18080
CHAT_TEMPERATURE=0
RETRY_ATTEMPTS=5
RETRY_DELAY_SEC=0.5