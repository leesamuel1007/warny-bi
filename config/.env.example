# WARNY-BI local FOSS RAG settings.
# Copy this file to .env and fill in local secrets.
# Do not commit .env.

# SQL Server
WARNY_SQL_DRIVER=ODBC Driver 18 for SQL Server
WARNY_SQL_SERVER=127.0.0.1,1433
WARNY_SQL_DATABASE=warny_bi
WARNY_SQL_USER=warny_ingest
WARNY_SQL_PASSWORD=CHANGE_ME

# Optional: use this instead of the individual SQL fields above.
# WARNY_SQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=127.0.0.1,1433;DATABASE=warny_bi;UID=warny_ingest;PWD=CHANGE_ME;Encrypt=yes;TrustServerCertificate=yes;

# SQL retrieval view
WARNY_SQL_VIEW=dbo.vw_rag_documents

# Qdrant
WARNY_QDRANT_URL=http://127.0.0.1:16333
WARNY_QDRANT_COLLECTION=warny_bi_rag

# Ollama
WARNY_OLLAMA_URL=http://127.0.0.1:11434
WARNY_EMBED_MODEL=mxbai-embed-large
WARNY_CHAT_MODEL=qwen2.5:14b
WARNY_OLLAMA_TIMEOUT=120

# Ingestion behavior
WARNY_EMBED_BATCH_SIZE=16
WARNY_TEST_QUERY=2020 Hyundai Elantra yellow engine light recall
WARNY_TEST_LIMIT=5

# FastAPI service
# Use 127.0.0.1 for local-only access.
# Use 0.0.0.0 only when exposing FastAPI to another machine on a trusted
# LAN/VPN path. SQL Server, Qdrant, and Ollama should remain local-only.
WARNY_API_HOST=127.0.0.1
WARNY_API_PORT=18080
WARNY_DEFAULT_TOP_K=5
WARNY_MAX_EVIDENCE_CHARS=800
WARNY_CHAT_TEMPERATURE=0
WARNY_CANDIDATE_MULTIPLIER=4
WARNY_MAX_CANDIDATES=30

# Prompt templates
WARNY_ANSWER_PROMPT_PATH=config/prompts/rag_answer.txt
WARNY_EVIDENCE_PROMPT_PATH=config/prompts/evidence_block.txt
WARNY_INTENT_PROMPT_PATH=config/prompts/query_intent.txt

# Optional FOSS query logging.
# Keep this off unless dbo.query_log and dbo.vw_query_log have been created by
# scripts/sql/05_create_query_log.sql in the target SQL database.
WARNY_LOG_ENABLED=false
WARNY_LOG_PIPELINE=foss_fastapi

# By default, logging reuses WARNY_SQL_* values. Override these if the FOSS API
# should log to Azure SQL while retrieval still uses local Qdrant.
# WARNY_LOG_SQL_DRIVER=ODBC Driver 18 for SQL Server
# WARNY_LOG_SQL_SERVER=freewarnybisqlserver.database.windows.net
# WARNY_LOG_SQL_DATABASE=free-warny-bi-sql-database
# WARNY_LOG_SQL_USER=warny_logger
# WARNY_LOG_SQL_PASSWORD=CHANGE_ME
# WARNY_LOG_SQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=freewarnybisqlserver.database.windows.net;DATABASE=free-warny-bi-sql-database;UID=warny_logger;PWD=CHANGE_ME;Encrypt=yes;TrustServerCertificate=no;
