# WARNY-BI local FOSS RAG settings.
# Copy this file to .env and fill in local secrets.
# Do not commit .env.

# SQL Server
WARNY_SQL_DRIVER=ODBC Driver 18 for SQL Server
WARNY_SQL_SERVER=127.0.0.1,1433
WARNY_SQL_DATABASE=warny_bi
WARNY_SQL_USER=warny_ingest
WARNY_SQL_PASSWORD=CHANGE_ME

# Optional: use this instead of the individual SQL fields above.
# WARNY_SQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=127.0.0.1,1433;DATABASE=warny_bi;UID=warny_ingest;PWD=CHANGE_ME;Encrypt=yes;TrustServerCertificate=yes;

# SQL retrieval view
WARNY_SQL_VIEW=dbo.vw_rag_documents

# Qdrant
WARNY_QDRANT_URL=http://127.0.0.1:16333
WARNY_QDRANT_COLLECTION=warny_bi_rag

# Ollama
WARNY_OLLAMA_URL=http://127.0.0.1:11434
WARNY_EMBED_MODEL=mxbai-embed-large
WARNY_CHAT_MODEL=qwen2.5:14b
WARNY_OLLAMA_TIMEOUT=120

# Ingestion behavior
WARNY_EMBED_BATCH_SIZE=16
WARNY_TEST_QUERY=2020 Hyundai Elantra yellow engine light recall
WARNY_TEST_LIMIT=5

# FastAPI service
WARNY_API_HOST=127.0.0.1
WARNY_API_PORT=18080
WARNY_DEFAULT_TOP_K=5
WARNY_MAX_EVIDENCE_CHARS=800
WARNY_CHAT_TEMPERATURE=0
WARNY_CANDIDATE_MULTIPLIER=4
WARNY_MAX_CANDIDATES=30

# Prompt templates
WARNY_ANSWER_PROMPT_PATH=config/prompts/rag_answer.txt
WARNY_EVIDENCE_PROMPT_PATH=config/prompts/evidence_block.txt
